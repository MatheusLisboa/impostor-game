rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: themes
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - words: list (required, min 50 strings)
    //   - category: string (required)
    //   - updated_at: timestamp (required)
    //   - is_custom: bool (optional)
    //   - created_by: string (optional, UID)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == "matheus.fillipe.farias.lisboa@gmail.com" && 
              request.auth.token.email_verified == true);
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidTheme(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.words is list && data.words.size() >= 1 &&
             data.category is string &&
             data.updated_at is timestamp;
    }

    match /temas/{themeId} {
      // Anyone can read themes (public themes)
      allow read: if true;
      
      // Allow creation for seeding or by authenticated users
      allow create: if isValidTheme(request.resource.data) && 
                    (request.resource.data.is_custom == false || isAuthenticated());
      
      // Allow update if:
      // 1. User is admin
      // 2. User is owner of a custom theme
      // 3. It's a default theme being updated (for seeding/sync)
      allow update: if isValidTheme(request.resource.data) && 
                    (isAdmin() || 
                     (isAuthenticated() && resource.data.created_by == request.auth.uid) ||
                     (resource.data.is_custom == false));
      
      // Only owners or admins can delete
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.created_by == request.auth.uid);
    }
  }
}
